---
import '../styles/global.css';
interface Props {
  title: string; description: string; slug?: string;
  type?: string; image?: string; date?: string;
}
const { title, description, slug = '', type = 'website', image, date } = Astro.props;
const GA_ID   = 'G-5TX067SHH1';
const ADSENSE_RAW_ID = import.meta.env.PUBLIC_ADSENSE_CLIENT_ID || import.meta.env.PUBLIC_GOOGLE_ADSENSE_CLIENT_ID || '';
const ADSENSE_PUBLISHER_ID = ADSENSE_RAW_ID.replace(/^ca-/, '');
const ADSENSE_CLIENT_ID = ADSENSE_PUBLISHER_ID ? `ca-${ADSENSE_PUBLISHER_ID}` : '';
const siteUrl = 'https://histolore.com';
const ogImage = image || `${siteUrl}/og-default.png`;
const canonical = slug ? `${siteUrl}/${slug}/` : siteUrl;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="SQe2DknX7LTVxeKpmYbZCF_czbm-uNTfAcbaSqo6kqI" />
  {ADSENSE_CLIENT_ID && <meta name="google-adsense-account" content={ADSENSE_CLIENT_ID} />}
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type"        content={type === 'website' ? 'website' : 'article'} />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:site_name"   content="Histolore" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style"
    href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800;900&family=Nunito:wght@400;500;600&display=swap"
    onload="this.onload=null;this.rel='stylesheet'" />
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800;900&family=Nunito:wght@400;500;600&display=swap" />
  </noscript>
  <link rel="alternate" type="application/rss+xml" title="Histolore Feed" href="/rss.xml" />
  <script>
    (() => {
      const stored = localStorage.getItem('histolore-theme');
      document.documentElement.dataset.theme = stored || 'dark';
    })();
  </script>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Histolore',
    url: siteUrl,
    description: 'Fascinating history explained clearly — events, people and mysteries for the endlessly curious.',
  })} />
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
  <script define:vars={{ GA_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date()); gtag('config', GA_ID);
  </script>
  {ADSENSE_CLIENT_ID && (
    <script
      async
      crossorigin="anonymous"
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT_ID}`}
    />
  )}
</head>
<body class="min-h-screen flex flex-col">
  <slot />
</body>
</html>
