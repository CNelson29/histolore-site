---
import Base    from '../layouts/Base.astro';
import Header  from '../components/Header.astro';
import Footer  from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => a.data.date < b.data.date ? 1 : -1);

const CATS = ['Action','Romance','Fantasy','Isekai','Completed','Rankings'];
const bycat = (cat: string) => all.filter(p => p.data.category === cat);
const featured = all.slice(0, 6);
const rest = all.slice(6);
---
<Base
  title="Histolore — The Stories Behind History's Greatest Moments"
  description="Fascinating history explained clearly — ancient civilizations, wars, unsolved mysteries and the people who shaped the world. New stories every day."
>
  <Header />
  <main class="flex-1">

    <!-- ═══ HERO ═══════════════════════════════════════════════════ -->
    <section class="relative overflow-hidden py-20 sm:py-28">
      <div class="speed-lines absolute inset-0 opacity-30 pointer-events-none"></div>
      <!-- Glow blobs -->
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-brand-coral/5 rounded-full blur-[120px] pointer-events-none"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-brand-teal/5 rounded-full blur-[100px] pointer-events-none"></div>

      <div class="relative max-w-6xl mx-auto px-4 sm:px-6 text-center">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-coral/20
                    bg-brand-coral/5 text-brand-coral text-xs font-bold mb-6 uppercase tracking-wider">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-coral animate-pulse"></span>
          Updated daily
        </div>

        <h1 class="font-display font-black text-4xl sm:text-5xl lg:text-7xl text-brand-white leading-none mb-4">
          The Stories Behind<br />
          <span class="gradient-text-coral">History's Greatest Moments</span>
        </h1>

        <p class="text-brand-dim text-lg sm:text-xl max-w-lg mx-auto mb-8 leading-relaxed font-sans">
          Ancient civilizations, wars, mysteries & the people who changed everything.<br />
          Well-researched — explained for the curious.
        </p>

        <!-- Category pills -->
        <div class="flex flex-wrap justify-center gap-2 mb-10">
          {CATS.map(cat => (
            <a href={`/#${cat.toLowerCase()}`}
              class={`cat-badge cat-${cat} hover:scale-105 transition-transform cursor-pointer`}>
              {cat}
            </a>
          ))}
        </div>

        <!-- Stats -->
        <div class="flex flex-col sm:flex-row justify-center gap-8 sm:gap-16">
          {[
            { v: `${all.length}+`, l: 'Stories published' },
            { v: 'Daily',          l: 'New history explained' },
            { v: '100%',           l: 'Researched & sourced' },
          ].map(({ v, l }) => (
            <div class="text-center">
              <div class="font-display font-black text-3xl text-brand-coral">{v}</div>
              <div class="text-brand-dim text-sm mt-0.5">{l}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ═══ FEATURED GRID ═══════════════════════════════════════════ -->
    <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-8">
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-display font-bold text-xl text-brand-white">🔥 Latest Rankings</h2>
        <span class="text-brand-dim text-sm">{all.length} lists</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
        {featured.map(p => (
          <PostCard title={p.data.title} slug={p.slug} excerpt={p.data.excerpt}
            date={p.data.date} category={p.data.category} tags={p.data.tags} />
        ))}
      </div>
      {rest.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {rest.map(p => (
            <PostCard title={p.data.title} slug={p.slug} excerpt={p.data.excerpt}
              date={p.data.date} category={p.data.category} tags={p.data.tags} />
          ))}
        </div>
      )}
    </section>

    <!-- ═══ BY CATEGORY ════════════════════════════════════════════ -->
    {CATS.filter(c => bycat(c).length > 0).map(cat => (
      <section class="max-w-6xl mx-auto px-4 sm:px-6 pb-10" id={cat.toLowerCase()}>
        <div class="flex items-center gap-3 mb-5">
          <h2 class="font-display font-bold text-lg text-brand-white">{cat}</h2>
          <span class={`cat-badge cat-${cat}`}>{bycat(cat).length} lists</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {bycat(cat).slice(0, 3).map(p => (
            <PostCard title={p.data.title} slug={p.slug} excerpt={p.data.excerpt}
              date={p.data.date} category={p.data.category} tags={p.data.tags} />
          ))}
        </div>
      </section>
    ))}

    <!-- ═══ CTA BAND ══════════════════════════════════════════════ -->
    <section class="border-t border-brand-border/50 bg-gradient-to-r from-brand-surface/50 via-brand-bg to-brand-surface/50 py-14">
      <div class="max-w-xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="font-display font-black text-2xl text-brand-white mb-3">
          New history stories every day 🏛️
        </h2>
        <p class="text-brand-dim mb-5 text-sm">Subscribe to the RSS feed to never miss a story.</p>
        <a href="/rss.xml"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-brand-coral/30
                 bg-brand-coral/5 text-brand-coral font-bold text-sm hover:bg-brand-coral/10 transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
          Subscribe via RSS
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
