---
import Base   from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post }    = Astro.props;
const { data }    = post;
const { Content } = await post.render();
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => a.data.date < b.data.date ? 1 : -1);
const relatedPosts = allPosts
  .filter(p => p.slug !== post.slug)
  .sort((a, b) => {
    const aScore = a.data.category === data.category ? 0 : 1;
    const bScore = b.data.category === data.category ? 0 : 1;
    return aScore - bScore || (a.data.date < b.data.date ? 1 : -1);
  })
  .slice(0, 4);

const dateFormatted = new Date(data.date).toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
});
const canonical = `https://curioushistory.net/${post.slug}/`;
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  description: data.excerpt,
  datePublished: data.date,
  dateModified: data.date,
  mainEntityOfPage: canonical,
  url: canonical,
  image: data.image ? `https://curioushistory.net${data.image}` : 'https://curioushistory.net/og-default.png',
  author: {
    '@type': 'Organization',
    name: 'Curious History',
    url: 'https://curioushistory.net',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Curious History',
    url: 'https://curioushistory.net',
  },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://curioushistory.net/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: data.category,
      item: `https://curioushistory.net/#${data.category.toLowerCase()}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: data.title,
      item: canonical,
    },
  ],
};

const GRAD: Record<string, string> = {
  Action:'from-brand-coral/15', Romance:'from-pink-500/15',
  Fantasy:'from-purple-500/15', Isekai:'from-blue-500/15',
  Completed:'from-brand-teal/15', Rankings:'from-amber-500/15',
};
const grad = GRAD[data.category] ?? GRAD.Rankings;
---
<Base
  title={`${data.title} | Curious History`}
  description={data.excerpt}
  slug={post.slug}
  type="article"
  date={data.date}
>
  <Header />
  <main class="flex-1">
    <!-- Hero -->
    <div class={`bg-gradient-to-b ${grad} to-brand-bg border-b border-brand-border/40 py-10 relative overflow-hidden`}>
      <div class="speed-lines absolute inset-0 opacity-20"></div>
      <div class="relative max-w-3xl mx-auto px-4 sm:px-6">
        <nav class="flex items-center gap-2 text-sm text-brand-dim mb-5">
          <a href="/" class="hover:text-brand-coral transition-colors">Home</a>
          <span>›</span>
          <span class={`cat-badge cat-${data.category}`}>{data.category}</span>
        </nav>
        <h1 class="font-display font-black text-3xl sm:text-4xl text-brand-white leading-tight mb-4">
          {data.title}
        </h1>
        <p class="text-brand-dim text-base leading-relaxed mb-4">{data.excerpt}</p>
        <div class="flex items-center gap-3 text-sm text-brand-dim">
          <span>📅 {dateFormatted}</span>
          {data.tags.slice(0,3).map(t => (
            <span class="px-2 py-0.5 rounded-full bg-brand-surface border border-brand-border text-xs">{t}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Cover image -->
    {data.image && (
      <div class="max-w-3xl mx-auto px-4 sm:px-6 -mt-4 mb-0">
        <img
          src={data.image}
          alt={data.title}
          class="w-full h-56 sm:h-72 object-cover rounded-2xl border border-brand-border/40 shadow-lg"
          loading="eager"
        />
      </div>
    )}

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-10">
      <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
      <article class="prose prose-invert max-w-none">
        <Content />
      </article>

      {relatedPosts.length > 0 && (
        <section class="mt-10">
          <div class="flex items-center justify-between gap-3 mb-4">
            <h2 class="font-display font-black text-xl text-brand-white">Related history stories</h2>
            <a href="/" class="text-sm font-bold text-brand-coral hover:text-orange-300 transition-colors">
              View all
            </a>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {relatedPosts.map(related => (
              <a
                href={`/${related.slug}/`}
                class="block rounded-xl border border-brand-border bg-brand-surface/60 p-4 no-underline transition-colors hover:border-brand-coral/40"
              >
                <div class={`cat-badge cat-${related.data.category} mb-3`}>{related.data.category}</div>
                <h3 class="font-display text-base font-bold leading-snug text-brand-white">
                  {related.data.title}
                </h3>
                <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-brand-dim">
                  {related.data.excerpt}
                </p>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Keep exploring CTA -->
      <div class="mt-10 p-6 rounded-2xl border border-brand-coral/20 bg-brand-surface text-center">
        <p class="font-display font-bold text-lg text-brand-white mb-1">Curious for more? 🏛️</p>
        <p class="text-brand-dim text-sm mb-4">New history stories are published every day — explore by era or subscribe to the feed.</p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href="/"
            class="px-4 py-2 rounded-lg bg-brand-coral text-white font-bold text-sm hover:bg-orange-400 transition-colors">
            Browse all stories
          </a>
          <a href="/rss.xml"
            class="px-4 py-2 rounded-lg bg-brand-surface border border-brand-border text-brand-text font-bold text-sm hover:border-brand-coral/40 transition-colors">
            RSS feed
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
