---
interface Props {
  title: string; slug: string; excerpt: string;
  date: string; category: string; tags?: string[];
}
const { title, slug, excerpt, date, category, tags = [] } = Astro.props;

const GRAD: Record<string, string> = {
  Action:    'from-brand-coral/20 to-brand-bg',
  Romance:   'from-pink-500/20 to-brand-bg',
  Fantasy:   'from-purple-500/20 to-brand-bg',
  Isekai:    'from-blue-500/20 to-brand-bg',
  Completed: 'from-brand-teal/20 to-brand-bg',
  Rankings:  'from-amber-500/20 to-brand-bg',
};
const ICON: Record<string, string> = {
  Action:'⚔️', Romance:'💕', Fantasy:'✨', Isekai:'🌀', Completed:'✅', Rankings:'🏆',
};
const grad  = GRAD[category]  ?? GRAD.Rankings;
const icon  = ICON[category]  ?? '📖';
const catCls = `cat-${category}` in {} ? '' : `cat-${category}`;

const dateFormatted = new Date(date).toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric',
});
---
<a href={`/${slug}/`} class="card-manga block no-underline group">
  <!-- Gradient header -->
  <div class={`bg-gradient-to-br ${grad} h-32 flex items-center justify-center relative overflow-hidden`}>
    <div class="speed-lines absolute inset-0 opacity-60"></div>
    <span class="text-5xl relative z-10 drop-shadow-lg">{icon}</span>
    <div class="absolute top-3 left-3">
      <span class={`cat-badge cat-${category}`}>{category}</span>
    </div>
  </div>

  <div class="p-4 flex flex-col gap-2">
    <h2 class="font-display font-bold text-brand-white text-base leading-snug line-clamp-2
               group-hover:text-brand-coral transition-colors">
      {title}
    </h2>

    <p class="text-brand-dim text-sm leading-relaxed line-clamp-2">{excerpt}</p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-1 mt-0.5">
        {tags.slice(0, 3).map(t => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-brand-surface border border-brand-border text-brand-dim">
            {t}
          </span>
        ))}
      </div>
    )}

    <div class="flex items-center justify-between pt-2 mt-auto border-t border-brand-border/40">
      <span class="text-xs text-brand-dim">{dateFormatted}</span>
      <span class="text-xs font-semibold text-brand-coral flex items-center gap-1
                   group-hover:gap-2 transition-all">
        Read
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
        </svg>
      </span>
    </div>
  </div>
</a>
