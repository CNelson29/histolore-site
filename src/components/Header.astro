---
import SiteControls from './SiteControls.astro';
const { pathname } = Astro.url;
const CATS = ['Ancient','Wars','Mysteries','People','Science'];
---
<header class="sticky top-0 z-50 border-b border-brand-border/60 bg-brand-bg/85 backdrop-blur-md">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2.5 group flex-shrink-0">
      <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-brand-coral to-orange-500 flex items-center justify-center shadow-lg shadow-brand-coral/20">
        <span class="text-white font-black text-sm font-display">H</span>
      </div>
      <span class="font-display font-black text-lg text-brand-white group-hover:text-brand-coral transition-colors">
        Histo<span class="text-brand-coral">lore</span>
      </span>
    </a>

    <!-- Category pills — desktop -->
    <div class="hidden md:flex items-center gap-1">
      {CATS.map(cat => (
        <a href={`/#${cat.toLowerCase()}`}
          class="px-3 py-1 rounded-lg text-xs font-semibold transition-colors text-brand-dim hover:text-brand-white hover:bg-brand-surface uppercase tracking-wide">
          {cat}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <a href="/quiz/"
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-brand-coral text-white hover:bg-orange-400 transition-colors text-xs font-bold">
        🏛️ History Quiz
      </a>
      <SiteControls />
      <a href="/rss.xml"
        class="hidden sm:flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-brand-border text-brand-dim hover:text-brand-coral hover:border-brand-coral/30 transition-colors text-xs font-semibold">
        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
        </svg>
        RSS
      </a>
    </div>
  </nav>
</header>
