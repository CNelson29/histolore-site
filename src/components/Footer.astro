---
const year = new Date().getFullYear();
---
<footer class="mt-auto border-t border-brand-border/50 bg-brand-surface/30 py-10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col md:flex-row justify-between gap-6 mb-6">
      <div>
        <div class="flex items-center gap-2 mb-2">
          <div class="w-7 h-7 rounded-xl bg-gradient-to-br from-brand-coral to-orange-500 flex items-center justify-center">
            <span class="text-white font-black text-xs font-display">C</span>
          </div>
          <span class="font-display font-black text-brand-white">Curious<span class="text-brand-coral">History</span></span>
        </div>
        <p class="text-brand-dim text-sm max-w-xs leading-relaxed">
          The stories behind history's most fascinating events, people and mysteries — explained clearly, every day.
        </p>
      </div>

      <div class="flex gap-10">
        <div>
          <h4 class="text-brand-white font-semibold text-sm mb-2">Categories</h4>
          <ul class="space-y-1.5 text-sm">
            {['Ancient','Wars','Mysteries','People','Science'].map(c => (
              <li><a href={`/#${c.toLowerCase()}`} class="text-brand-dim hover:text-brand-coral transition-colors">{c}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <h4 class="text-brand-white font-semibold text-sm mb-2">Site</h4>
          <ul class="space-y-1.5 text-sm">
            <li><a href="/" class="text-brand-dim hover:text-brand-coral transition-colors">Home</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="pt-5 border-t border-brand-border/50 flex flex-col sm:flex-row justify-between gap-2 text-xs text-brand-dim">
      <p>© {year} Curious History. All rights reserved.</p>
      <p>Well-researched history, explained for the curious.</p>
    </div>
  </div>
</footer>
